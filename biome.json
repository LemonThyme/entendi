{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["src/**", "tests/**", "esbuild.config.ts", "vitest.config.ts", "plugin/**/*.ts", "!src/dashboard/dashboard.js"]
	},
	"formatter": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noForEach": "off",
				"noStaticOnlyClass": "off",
				"useLiteralKeys": "off",
				"useArrowFunction": "off"
			},
			"style": {
				"noNonNullAssertion": "off",
				"useNumberNamespace": "off",
				"noParameterAssign": "off",
				"useDefaultParameterLast": "off",
				"useNodejsImportProtocol": "off",
				"useTemplate": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noAssignInExpressions": "off",
				"noNonNullAssertedOptionalChain": "off"
			},
			"correctness": {
				"noUnusedImports": "warn",
				"noUnusedVariables": "warn",
				"noInnerDeclarations": "off"
			}
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
