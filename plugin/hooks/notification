#!/usr/bin/env bash
# Notification hook (idle_prompt) — reminds user about pending probes
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
LOG_DIR="${HOME}/.entendi"
LOG_FILE="${LOG_DIR}/debug.log"

mkdir -p "$LOG_DIR"

INPUT=$(cat)

if [ -z "$INPUT" ]; then
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] [hook:notification:bash] empty stdin, exiting" >> "$LOG_FILE"
  exit 0
fi

echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] [hook:notification:bash] invoking node, input length=${#INPUT}" >> "$LOG_FILE"

OUTPUT=""
STDERR_OUTPUT=""
EXIT_CODE=0
OUTPUT=$(echo "$INPUT" | node "${PLUGIN_ROOT}/hooks/notification.js" 2>"${LOG_DIR}/hook-stderr.tmp") || EXIT_CODE=$?
STDERR_OUTPUT=$(cat "${LOG_DIR}/hook-stderr.tmp" 2>/dev/null || true)
rm -f "${LOG_DIR}/hook-stderr.tmp"

echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] [hook:notification:bash] exit=$EXIT_CODE output_len=${#OUTPUT} stderr=${STDERR_OUTPUT:0:200}" >> "$LOG_FILE"

if [ -n "$OUTPUT" ]; then
  ESCAPED_OUTPUT=$(node -e "process.stdout.write(JSON.stringify(process.argv[1]))" -- "$OUTPUT" 2>/dev/null || printf '"%s"' "$OUTPUT")
  printf '{"suppressOutput":true,"additionalContext":%s}' "$ESCAPED_OUTPUT"
fi

exit 0
