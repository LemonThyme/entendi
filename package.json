{
  "name": "entendi",
  "version": "0.2.0",
  "description": "Comprehension accountability layer for AI-assisted work",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "node -e \"const f='src/dashboard/manifest.ts';require('fs').existsSync(f)||require('fs').writeFileSync(f,'export const manifest: Record<string, string> = {};\\n')\" && npx tsc && node --import tsx esbuild.config.ts",
    "build:hooks": "node --import tsx esbuild.config.ts",
    "plugin:reinstall": "rm -rf ~/.claude/plugins/cache/entendi && npm run build && rm -rf ~/.claude/plugins/cache/entendi && claude plugin install entendi",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/api/db/seed.ts",
    "db:migrate:run": "tsx src/api/db/migrate.ts",
    "api:dev": "tsx src/api/index.ts",
    "deploy:staging": "npx wrangler deploy --env staging"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@neondatabase/serverless": "^1.0.2",
    "better-auth": "^1.4.19",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.2",
    "resend": "^6.9.2",
    "stripe": "^20.4.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "echarts": "^6.0.0",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.68.1"
  }
}
