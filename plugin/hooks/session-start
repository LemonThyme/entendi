#!/usr/bin/env bash
# SessionStart hook — injects Entendi concept detection skill.
# Runs on every startup/resume/clear/compact since context is lost each time.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
LOG_DIR="${HOME}/.entendi"
LOG_FILE="${LOG_DIR}/debug.log"

mkdir -p "$LOG_DIR"

log() {
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] [hook:session-start:bash] $1" >> "$LOG_FILE"
}

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Read and inject the concept-detection skill
SKILL_CONTENT=$(cat "${PLUGIN_ROOT}/skills/concept-detection/SKILL.md" 2>/dev/null || echo "Error reading concept-detection skill")

SKILL_ESCAPED=$(escape_for_json "$SKILL_CONTENT")

log "injecting concept-detection skill (${#SKILL_CONTENT} bytes)"

cat <<EOF
{
  "suppressOutput": true,
  "statusMessage": "Entendi connected",
  "additional_context": "${SKILL_ESCAPED}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${SKILL_ESCAPED}"
  }
}
EOF

exit 0
